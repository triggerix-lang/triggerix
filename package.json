{
  "name": "@triggerix/monorepo",
  "type": "module",
  "version": "0.0.5",
  "private": true,
  "packageManager": "pnpm@11.7.0",
  "description": "A language-agnostic trigger schema for defining events, conditions and actions",
  "license": "MIT",
  "homepage": "https://github.com/triggerix-lang/triggerix#readme",
  "repository": {
    "type": "git",
    "url": "git@github.com:triggerix-lang/triggerix.git"
  },
  "bugs": {
    "url": "https://github.com/triggerix-lang/triggerix/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "stub": "pnpm -r run stub",
    "build": "pnpm -r run build",
    "lint": "eslint --cache",
    "release": "bumpp -r",
    "update-readme": "esno scripts/update-readme.ts",
    "test": "vitest run",
    "prepare": "simple-git-hooks"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^9.0.0",
    "bumpp": "^11.1.0",
    "defu": "^6.1.7",
    "eslint": "^10.5.0",
    "esno": "^4.8.0",
    "nano-staged": "^1.0.2",
    "simple-git-hooks": "^2.13.1",
    "typescript": "^6.0.3",
    "unbuild": "^3.6.1",
    "vitest": "^3.2.1"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm nano-staged"
  },
  "nano-staged": {
    "*": "eslint --cache --fix"
  }
}
